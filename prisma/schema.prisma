generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  MANAGER
  STAFF
}

enum SubscriptionPlan {
  STARTER
  GROWTH
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
}

enum CustomerTag {
  VIP
  REGULAR
  INACTIVE
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
}

enum CampaignSegment {
  VIP
  INACTIVE
  HIGH_SPENDERS
  ALL
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
  ADJUST
}

enum ShiftRole {
  SERVER
  HOST
  BARTENDER
  CHEF
  MANAGER
}

enum AnalyticsEventType {
  RESERVATION_CREATED
  RESERVATION_COMPLETED
  REVENUE_RECORDED
  CUSTOMER_VISIT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  memberships  Membership[]
  chatMessages ChatMessage[]
  shifts       Shift[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Restaurant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  address   String?
  phone     String?
  timezone  String   @default("Europe/London")
  currency  String   @default("GBP")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships         Membership[]
  subscription        Subscription?
  customers           Customer[]
  reservations        Reservation[]
  tables              Table[]
  loyaltyAccounts     LoyaltyAccount[]
  loyaltyTransactions LoyaltyTransaction[]
  loyaltyRules        LoyaltyRule[]
  campaigns           Campaign[]
  automationRules     AutomationRule[]
  shifts              Shift[]
  analyticsEvents     AnalyticsEvent[]
  chatMessages        ChatMessage[]
  timeSlots           TimeSlot[]
  emailLogs           EmailLog[]
}

model Membership {
  id           String   @id @default(cuid())
  userId       String
  restaurantId String
  role         Role     @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([restaurantId])
}

model Subscription {
  id                   String             @id @default(cuid())
  restaurantId         String             @unique
  plan                 SubscriptionPlan   @default(STARTER)
  status               SubscriptionStatus @default(TRIALING)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model Customer {
  id           String        @id @default(cuid())
  restaurantId String
  firstName    String
  lastName     String
  email        String?
  phone        String?
  notes        String?       @db.Text
  tags         CustomerTag[]
  totalSpend   Decimal       @default(0) @db.Decimal(10, 2)
  visitCount   Int           @default(0)
  lastVisitAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  restaurant      Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  reservations    Reservation[]
  loyaltyAccount  LoyaltyAccount?
  analyticsEvents AnalyticsEvent[]

  @@index([restaurantId])
  @@index([restaurantId, email])
}

model Table {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  capacity     Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@index([restaurantId])
}

model TimeSlot {
  id           String   @id @default(cuid())
  restaurantId String
  dayOfWeek    Int
  startTime    String
  endTime      String
  maxCovers    Int      @default(50)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model Reservation {
  id           String            @id @default(cuid())
  restaurantId String
  customerId   String
  tableId      String?
  date         DateTime
  startTime    String
  endTime      String
  partySize    Int
  status       ReservationStatus @default(PENDING)
  notes        String?           @db.Text
  spendAmount  Decimal?          @db.Decimal(10, 2)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  table      Table?     @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([restaurantId, date])
  @@index([customerId])
}

model LoyaltyRule {
  id              String   @id @default(cuid())
  restaurantId    String
  name            String
  pointsPerPound  Decimal  @default(1) @db.Decimal(5, 2)
  minSpend        Decimal  @default(0) @db.Decimal(10, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model LoyaltyAccount {
  id           String   @id @default(cuid())
  restaurantId String
  customerId   String   @unique
  points       Int      @default(0)
  lifetimePts  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant   Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customer     Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]

  @@index([restaurantId])
}

model LoyaltyTransaction {
  id               String                 @id @default(cuid())
  restaurantId     String
  loyaltyAccountId String
  type             LoyaltyTransactionType
  points           Int
  description      String
  reservationId    String?
  createdAt        DateTime               @default(now())

  restaurant     Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  loyaltyAccount LoyaltyAccount @relation(fields: [loyaltyAccountId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([loyaltyAccountId])
}

model Campaign {
  id           String          @id @default(cuid())
  restaurantId String
  name         String
  subject      String
  body         String          @db.Text
  segment      CampaignSegment
  status       CampaignStatus  @default(DRAFT)
  sentAt       DateTime?
  recipientCount Int           @default(0)
  openRate     Float?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model EmailLog {
  id           String   @id @default(cuid())
  restaurantId String?
  campaignId   String?
  toEmail      String
  toName       String
  subject      String
  body         String   @db.Text
  status       String   @default("DELIVERED")
  sentAt       DateTime @default(now())

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([restaurantId, sentAt])
}

model AutomationRule {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  triggerDays  Int
  segment      CampaignSegment
  subject      String
  body         String   @db.Text
  isActive     Boolean  @default(true)
  lastRunAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model Shift {
  id           String    @id @default(cuid())
  restaurantId String
  userId       String
  date         DateTime
  startTime    String
  endTime      String
  role         ShiftRole @default(SERVER)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([restaurantId, date])
}

model AnalyticsEvent {
  id           String             @id @default(cuid())
  restaurantId String
  type         AnalyticsEventType
  value        Decimal?           @db.Decimal(10, 2)
  metadata     Json?
  customerId   String?
  recordedAt   DateTime           @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([restaurantId, recordedAt])
}

model ChatMessage {
  id           String   @id @default(cuid())
  restaurantId String
  userId       String
  role         String
  content      String   @db.Text
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([restaurantId, userId])
}
